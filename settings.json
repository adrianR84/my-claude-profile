{
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "91999",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "65",
    "ENABLE_TOOL_SEARCH": "true",
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_FORK_SUBAGENT": "0"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Read(**/.env*)",
      "Read(**/.dev.vars*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/config/database.yml)",
      "Read(**/config/credentials.json)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Write(**/.env*)",
      "Write(**/secrets/**)",
      "Write(**/.ssh/**)",
      "Write(.github/workflows/*)",
      "Bash(sudo *)",
      "Bash(npm publish *)",
      "Bash(curl * | sh)"
    ],
    "ask": [
      "Bash(git -C push *)",
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "playground@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "toast-notifications@claude-code-awesome": true,
    "protective-hooks@claude-code-awesome": true,
    "rss-aggregator@claude-code-awesome": true,
    "minimal-claude@claude-code-awesome": true,
    "micro-skill-pipeline@claude-code-awesome": false,
    "llm-wiki-compiler@claude-code-awesome": false,
    "tdd-guard@claude-code-awesome": false,
    "obsidian@claude-code-awesome": true,
    "agent-session-resume@claude-code-awesome": false,
    "all-permissions@claude-code-awesome": true,
    "last30days@claude-code-awesome": true
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true,
  "mcpServers": {}
}
